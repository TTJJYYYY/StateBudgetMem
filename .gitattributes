# Normalize text files in the repository to LF.
# This prevents Windows/Codex line-ending changes from making whole files look modified.
* text=auto eol=lf

# Source code and text
*.py      text eol=lf
*.pyi     text eol=lf
*.md      text eol=lf
*.txt     text eol=lf
*.toml    text eol=lf
*.yaml    text eol=lf
*.yml     text eol=lf
*.json    text eol=lf
*.jsonl   text eol=lf
*.csv     text eol=lf
*.ini     text eol=lf
*.cfg     text eol=lf
*.sh      text eol=lf
*.ps1     text eol=lf
*.bat     text eol=crlf
*.cmd     text eol=crlf

# Binary files
*.png     binary
*.jpg     binary
*.jpeg    binary
*.gif     binary
*.webp    binary
*.ico     binary
*.pdf     binary
*.zip     binary
*.7z      binary
*.rar     binary
*.gz      binary
*.tar     binary
*.woff    binary
*.woff2   binary
*.ttf     binary
*.otf     binary
*.pkl     binary
*.pickle  binary
*.npy     binary
*.npz     binary
*.faiss   binary
*.index   binary
*.pt      binary
*.pth     binary
*.ckpt    binary
*.onnx    binary
*.gguf    binary
*.safetensors binary
